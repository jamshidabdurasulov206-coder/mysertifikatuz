PORT=4000
NODE_ENV=development
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_HOST=localhost
DB_PORT=5432
# DB_SSL: set to "true" if your PostgreSQL server requires SSL, leave empty/false if not
DB_SSL=false
PAYME_MERCHANT_ID=your_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
CORS_ORIGIN=https://mysertifikat.uz

# AI (Claude) for open-answer scoring
ANTHROPIC_API_KEY=your_anthropic_api_key

# Queue/Redis for async AI evaluation (set to true to enable worker)
ENABLE_REDIS_QUEUE=true
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Optional: force-disable worker (overrides ENABLE_REDIS_QUEUE)
DISABLE_ATTEMPT_WORKER=false
